# ===== إعدادات البريد (Gmail SMTP) =====
# حساب Gmail المستخدم للإرسال
GMAIL_USER=Liirat.official.tr@gmail.com
# كلمة مرور التطبيق (App Password) من إعدادات أمان Google — 16 حرفاً
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# البريد الذي تصل إليه طلبات فتح الحساب
MAIL_TO=Liirat.official.tr@gmail.com

# ===== إعدادات بوت تلغرام =====
# رمز البوت من @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVwxyz
# معرّف مجموعة تلغرام (يبدأ غالباً بـ -100 للمجموعات الخارقة)
TELEGRAM_CHAT_ID=-1001234567890
